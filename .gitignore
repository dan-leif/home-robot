# VirtualBox disk images — large, download separately
*.vdi
*.vdi.zip

# Kokoro TTS model files — large, download separately
# See kokoro/README section for download instructions
kokoro/*.onnx
kokoro/*.bin

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Claude Code local settings (machine-specific, no secrets but not project code)
.claude/settings.local.json

# Local backup manifests (machine-specific state records; VM snapshots live in
# the VirtualBox VM folder, not here)
backups/

# Off-site backup config — holds the Samba password + HA token (DPAPI-encrypted,
# machine-specific). MUST NEVER be committed.
offsite-config.xml

# Logs
kokoro/*.log

# Whisper benchmark — runtime server/sweep logs and regenerable test audio
# (audio is regenerated by whisper-bench/gen_test_audio.py from the Kokoro models;
#  references.json + results/results.csv capture what was said and transcribed)
whisper-bench/*.log
whisper-bench/audio/

# Windows
Thumbs.db
Desktop.ini
